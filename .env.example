PORT=3000
NODE_ENV=development
# Required: the app reads DATABASE_URL automatically from this env var on startup.
DATABASE_URL=postgresql://postgres:password@localhost:5432/questionnaire_saas
# Optional but recommended for hosted PostgreSQL providers such as Render.
DATABASE_SSL=false
JWT_SECRET=change_me_to_a_long_random_secret
# Optional. In production on Render, if omitted the app can use RENDER_EXTERNAL_URL automatically.
APP_URL=http://localhost:3000

# PayPal hosted payment links / buttons
PAYPAL_ENV=live
PAYPAL_RECEIVER_EMAIL=your-paypal-business-email@example.com
PAYPAL_HOSTED_LINK_URL=https://www.paypal.com/ncp/payment/your-hosted-link-id
# Fixed amount configured on your hosted PayPal button. This is also stored on each receipt as the saved PayPal quote.
PAYPAL_EXPECTED_AMOUNT=55.00
PAYPAL_EXPECTED_CURRENCY=USD

# Temporary read-only viewer access for viewer.html auto-connect
VIEWER_USERNAME=viewer_user
VIEWER_PASSWORD=change_this_viewer_password
