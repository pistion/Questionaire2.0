PORT=3000
NODE_ENV=development
# Required: the app reads DATABASE_URL automatically from this env var on startup.
DATABASE_URL=postgresql://postgres:password@localhost:5432/questionnaire_saas
JWT_SECRET=change_me_to_a_long_random_secret
APP_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# PayPal hosted payment links / buttons
PAYPAL_ENV=live
PAYPAL_RECEIVER_EMAIL=merchant@example.com
# Fixed amount configured on your hosted PayPal button. This is also stored on each receipt as the saved PayPal quote.
PAYPAL_EXPECTED_AMOUNT=55.00
PAYPAL_EXPECTED_CURRENCY=USD

# Seed admin credentials (used by scripts/init-db.js)
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeThisPassword123!
